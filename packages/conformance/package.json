{
  "name": "@openstrux/conformance",
  "version": "0.0.0",
  "description": "Shared conformance test library for OpenStrux",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "check": "tsc --noEmit"
  },
  "files": ["dist", "src"],
  "license": "Apache-2.0",
  "devDependencies": {
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
