{
  "name": "@openstrux/validator",
  "version": "0.0.0",
  "description": "OpenStrux type-checker and semantic validator",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "check": "tsc --noEmit"
  },
  "files": ["dist", "src"],
  "license": "Apache-2.0",
  "dependencies": {
    "@openstrux/ast": "workspace:*",
    "@openstrux/parser": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.0",
    "vitest": "^2.0.0"
  }
}
